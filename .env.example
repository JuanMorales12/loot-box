# Loot Box System Environment Variables

# Application
NEXT_PUBLIC_APP_NAME="Loot Box System"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/lootbox

# Payment Gateway (for production)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Admin Access (for production)
# ADMIN_PASSWORD=your-secure-password

# Feature Flags
NEXT_PUBLIC_ENABLE_SHOP=true
NEXT_PUBLIC_ENABLE_ADMIN=true
